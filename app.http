## Global Variabel
#@BaseUrl = https://your-production-url.com:8080
@BaseUrl = http://127.0.0.1:8000

### ---------------------------------------
## Auth
### ---------------------------------------

### Melakukan pendaftaran
# @name PostRegister
POST {{BaseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Tester",
  "username": "tester",
  "password": "tester"
}

### Masuk ke layanan
# @name PostLogin
POST {{BaseUrl}}/auth/login
Content-Type: application/json

{
  "username": "tester",
  "password": "tester"
}

> {%
    client.global.set("authToken", response.body.data.authToken);
    client.global.set("refreshToken", response.body.data.refreshToken);
%}

### Keluar dari layanan
# @name PostLogout
POST {{BaseUrl}}/auth/logout
Content-Type: application/json

{
  "authToken": "{{authToken}}"
}

### Refresh token
# @name PostRefreshToken
POST {{BaseUrl}}/auth/refresh-token
Content-Type: application/json

{
  "authToken": "{{authToken}}",
  "refreshToken": "{{refreshToken}}"
}

> {%
    client.global.set("authToken", response.body.data.authToken);
    client.global.set("refreshToken", response.body.data.refreshToken);
%}

### ---------------------------------------
## Users
### ---------------------------------------

### Mengambil informasi akun
# @name GetUserMe
GET {{BaseUrl}}/users/me
Authorization: Bearer {{authToken}}
Content-Type: application/json

> {%
    client.global.set("userId", response.body.data.user.id);
%}

### Mengubah informasi akun
# @name PutUserMe
PUT {{BaseUrl}}/users/me
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "name": "Tester Update",
  "username": "tester"
}

### Mengubah kata sandi akun
# @name PutUserMePassword
PUT {{BaseUrl}}/users/me/password
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "newPassword": "tester",
  "password": "tester"
}

### Mengubah photo profile
# @name PutUserMePhoto
PUT {{BaseUrl}}/users/me/photo
Authorization: Bearer {{authToken}}
Content-Type: multipart/form-data; boundary=WebAppBoundary

--WebAppBoundary
Content-Disposition: form-data; name="file"; filename="example.png"
Content-Type: image/png

< ./uploads/examples/me.png
--WebAppBoundary--

### Mengambil photo profile
@userId = 00ed9d33-61b0-48b7-a32a-6510af028731

# @name GetMyPhoto
GET {{BaseUrl}}/images/users/{{userId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

### ---------------------------------------
## Lost & Found Items
### ---------------------------------------

### Mengambil semua item (filter opsional)
# @name GetItems
GET {{BaseUrl}}/items?search=&type=&category=&status=
Authorization: Bearer {{authToken}}
Content-Type: application/json

### Menambahkan item baru
# @name PostItem
POST {{BaseUrl}}/items
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "type": "LOST",
  "title": "Dompet Hitam",
  "description": "Dompet hitam berisi KTP dan kartu ATM",
  "category": "Wallet",
  "location": "Kantin Lantai 2",
  "date": "2024-01-15T10:00:00Z"
}

> {%
    client.global.set("itemId", response.body.data.itemId);
%}

### Mengambil item berdasarkan id
# @name GetItemById
GET {{BaseUrl}}/items/{{itemId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

### Mengubah data item
# @name PutItem
PUT {{BaseUrl}}/items/{{itemId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "type": "LOST",
  "title": "Dompet Hitam Update",
  "description": "Dompet hitam berisi KTP dan kartu ATM",
  "category": "Wallet",
  "location": "Kantin Lantai 2",
  "status": "ACTIVE",
  "date": "2024-01-15T10:00:00Z"
}

### Mengubah image item
# @name PutItemImage
PUT {{BaseUrl}}/items/{{itemId}}/image
Authorization: Bearer {{authToken}}
Content-Type: multipart/form-data; boundary=WebAppBoundary

--WebAppBoundary
Content-Disposition: form-data; name="file"; filename="example.png"
Content-Type: image/png

< ./uploads/examples/me.png
--WebAppBoundary--

### Mengambil image item
# @name GetItemImage
GET {{BaseUrl}}/images/items/{{itemId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

### Menghapus item
# @name DeleteItem
DELETE {{BaseUrl}}/items/{{itemId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json